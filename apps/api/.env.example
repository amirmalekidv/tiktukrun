# ============================================================
# TIK TAK RUN — API Environment Variables
# فاز ۲: متغیرهای محیطی کامل
#
# راهنما:
#   cp .env.example .env
#   مقادیر را برای محیط خود تنظیم کنید
#   هرگز فایل .env را به git commit نکنید!
# ============================================================

# ─── APP ─────────────────────────────────────────────────────
NODE_ENV=development
APP_NAME="TIK TAK RUN API"
APP_PORT=3001
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3002

# ─── DATABASE (PostgreSQL 16) ─────────────────────────────────
# فرمت: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://tiktakrun:tiktakrun_secret_2026@localhost:5432/tiktakrun_dev?schema=public"

# برای shadow database (مورد نیاز Prisma migrate)
SHADOW_DATABASE_URL="postgresql://tiktakrun:tiktakrun_secret_2026@localhost:5432/tiktakrun_shadow?schema=public"

# ─── REDIS ───────────────────────────────────────────────────
# برای کش، صف، Session و OTP
REDIS_URL="redis://:redis_secret_2026@localhost:6379"
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret_2026
REDIS_DB=0

# ─── JWT (توکن‌های احراز هویت) ──────────────────────────────
# حتماً یک رشته تصادفی بلند و امن بگذارید
JWT_SECRET="change_me_to_a_very_long_random_string_at_least_64_chars_for_security"
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET="another_very_long_random_string_for_refresh_token_security_2026"
JWT_REFRESH_EXPIRES_IN=30d

# ─── SMS (درگاه پیامک ایرانی) ────────────────────────────────
# سرویس‌های پشتیبانی‌شده: melipayamak, kavenegar, farazsms
SMS_PROVIDER=melipayamak
SMS_API_KEY=your_sms_api_key_here
SMS_API_SECRET=your_sms_api_secret_here
SMS_FROM=your_sms_number

# Kavenegar (اگر از این سرویس استفاده می‌کنید)
KAVENEGAR_API_KEY=your_kavenegar_api_key

# ─── PAYMENT (درگاه پرداخت) ─────────────────────────────────
# ZarinPal
ZARINPAL_MERCHANT_ID=your_zarinpal_merchant_id
ZARINPAL_SANDBOX=true
ZARINPAL_CALLBACK_URL=http://localhost:3001/api/payments/callback/zarinpal

# IDPay
IDPAY_API_KEY=your_idpay_api_key
IDPAY_SANDBOX=true
IDPAY_CALLBACK_URL=http://localhost:3001/api/payments/callback/idpay

# ─── STORAGE (ذخیره‌سازی فایل) ──────────────────────────────
# S3-Compatible (MinIO در dev، Arvan/Liara در prod)
STORAGE_PROVIDER=local  # local | s3 | arvan
STORAGE_LOCAL_PATH=./uploads

# S3 / ArvanCloud Object Storage
S3_ENDPOINT=https://s3.ir-thr-at1.arvanstorage.ir
S3_BUCKET=tiktakrun-media
S3_ACCESS_KEY=your_s3_access_key
S3_SECRET_KEY=your_s3_secret_key
S3_REGION=ir-thr-at1
S3_CDN_URL=https://tiktakrun-media.s3.ir-thr-at1.arvanstorage.ir

# ─── EMAIL ───────────────────────────────────────────────────
MAIL_PROVIDER=smtp  # smtp | sendgrid | mailhog
MAIL_FROM="TIK TAK RUN <noreply@tiktakrun.ir>"

# SMTP
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# SendGrid
SENDGRID_API_KEY=your_sendgrid_api_key

# ─── SECURITY ────────────────────────────────────────────────
# رمزنگاری داده‌های حساس
ENCRYPTION_KEY="32_char_hex_key_for_aes_encryption"

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# OTP
OTP_EXPIRE_MINUTES=5
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=3

# ─── AI / ML ─────────────────────────────────────────────────
# OpenAI برای چت‌بات و توصیه‌گر (اختیاری)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# ─── LOGGING ─────────────────────────────────────────────────
LOG_LEVEL=debug  # debug | info | warn | error
LOG_FORMAT=pretty  # pretty | json

# ─── MONITORING (Sentry) ─────────────────────────────────────
SENTRY_DSN=your_sentry_dsn_here
SENTRY_ENVIRONMENT=development

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGINS="http://localhost:3000,http://localhost:3002"

# ─── CACHE ───────────────────────────────────────────────────
CACHE_TTL=300   # ثانیه
CACHE_MAX=1000

# ─── GAMIFICATION ────────────────────────────────────────────
XP_PER_BOOKING=10
COINS_PER_BOOKING=20
WHEEL_COST_COINS=500
WHEEL_COST_DIAMONDS=5
INVITE_XP_REWARD=5

# ─── WORKER / QUEUE ──────────────────────────────────────────
BULL_REDIS_URL="redis://:redis_secret_2026@localhost:6379/1"
BULL_CONCURRENCY=5
