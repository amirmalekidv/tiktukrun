// ============================================================
// TIK TAK RUN — Prisma Schema — فاز ۲
// طراحی کامل دیتابیس پلتفرم رزرو سرگرمی
// ============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, citext]
}

// ============================================================
// ■ ENUMS
// ============================================================

/// نقش‌های سیستم — چندنقشی RBAC
enum UserRole {
  SUPER_ADMIN
  ADMIN
  BRANCH_MANAGER
  SUPPORT
  MARKETING
  CUSTOMER
}

/// وضعیت رزرو
enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  REFUNDED
}

/// وضعیت پرداخت
enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUND
}

/// روش پرداخت
enum PaymentMethod {
  WALLET
  ZARINPAL
  IDPAY
  BANK_TRANSFER
  CASH
}

/// نوع تراکنش کیف پول
enum TransactionType {
  DEPOSIT
  WITHDRAW
  BOOKING_PAYMENT
  REFUND
  WHEEL_SPEND
  WHEEL_WIN
  DIAMOND_PURCHASE
  COIN_PURCHASE
  INVITE_REWARD
  MONTHLY_REWARD
  MANUAL_ADJUST
  RATING_REWARD
}

/// نوع ارز / منبع
enum CurrencyType {
  TOMAN
  COINS
  DIAMONDS
  XP
}

/// نوع اتاق چت
enum ChatRoomType {
  GLOBAL
  TEAM
  PRIVATE
}

/// وضعیت پیام چت
enum ChatMessageStatus {
  NORMAL
  REPORTED
  HIDDEN
  DELETED
}

/// اولویت تیکت پشتیبانی
enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

/// وضعیت تیکت
enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_USER
  RESOLVED
  CLOSED
}

/// وضعیت کمپین
enum CampaignStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  PAUSED
  COMPLETED
}

/// نوع کمپین
enum CampaignType {
  SMS
  EMAIL
  INAPP
  PUSH
}

/// مرحله‌ی فروش در پایپ‌لاین CRM
enum PipelineStage {
  LEADS
  CONTACTED
  PROPOSED
  NEGOTIATING
  CLOSED_WON
  CLOSED_LOST
}

/// نوع تخفیف
enum DiscountType {
  PERCENT
  FIXED
}

/// نوع آیتم آواتار
enum AvatarItemType {
  HAT
  GLASSES
  SKIN
  EFFECT
  BACKGROUND
  ACCESSORY
}

/// نوع جایزه‌ی گردونه شانس
enum WheelPrizeType {
  COINS
  DIAMONDS
  XP
  DISCOUNT_CODE
  FREE_TICKET
  TOMAN
}

/// رتبه‌بندی لول (هر ۵ لول یک رتبه)
enum LevelTier {
  BRONZE
  SILVER
  GOLD
  LEGEND
}

/// نوع اعلان
enum NotificationType {
  BOOKING
  PAYMENT
  LEVEL
  BADGE
  WHEEL
  TEAM
  CHAT
  SYSTEM
  PROMOTION
}

/// کانال ارسال اعلان
enum NotificationChannel {
  INAPP
  SMS
  EMAIL
}

/// سطح دشواری بازی
enum GameDifficulty {
  EASY
  MEDIUM
  HARD
  VERY_HARD
  LEGENDARY
}

/// فیلتر ژانر بازی
enum GenreFilter {
  HORROR
  NON_HORROR
}

/// نوع اکشن مدیریت چت
enum ModerationActionType {
  WARN
  MUTE_24H
  BAN
  DELETE_MSG
}

/// وضعیت تیم
enum TeamStatus {
  FORMING
  FULL
  COMPLETED
  CANCELLED
}

/// نقش عضو تیم
enum TeamMemberRole {
  CAPTAIN
  MEMBER
}

/// نوع برنده ماهانه
enum MonthlyWinnerType {
  TOP_PLAYER
  TOP_TEAM
  TOP_GAME
}

/// نوع قانون تخفیف خودکار
enum AutoDiscountRule {
  VIP
  WEEKLY
  FIRST_BOOKING
  BIRTHDAY
  INVITE
}

/// جنسیت کاربر
enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

// ============================================================
// ■ MODELS
// ============================================================

// ─── جغرافیا ────────────────────────────────────────────────

/// شهرها — چندشهر
model City {
  id           Int      @id @default(autoincrement())
  /// نام شهر به فارسی
  name         String
  slug         String   @unique
  isActive     Boolean  @default(true)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  branches Branch[]
  profiles UserProfile[]

  @@index([slug])
  @@map("cities")
}

/// شعب — هر شهر چند شعبه
model Branch {
  id        Int      @id @default(autoincrement())
  /// نام شعبه
  name      String
  cityId    Int
  address   String
  phone     String?
  /// عرض جغرافیایی
  lat       Decimal? @db.Decimal(10, 8)
  /// طول جغرافیایی
  lng       Decimal? @db.Decimal(11, 8)
  isActive  Boolean  @default(true)
  /// مدیر شعبه (کاربر با نقش BRANCH_MANAGER)
  managerId Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  city    City     @relation(fields: [cityId], references: [id], onDelete: Restrict)
  manager User?    @relation("BranchManager", fields: [managerId], references: [id], onDelete: SetNull)
  games   Game[]
  bookings Booking[]
  tickets  Ticket[]
  teams    Team[]

  @@index([cityId])
  @@index([isActive])
  @@map("branches")
}

// ─── بازی‌ها ─────────────────────────────────────────────────

/// دسته‌بندی بازی‌ها
model Category {
  id           Int         @id @default(autoincrement())
  /// نام دسته‌بندی به فارسی
  name         String
  slug         String      @unique
  /// آیکون FontAwesome یا emoji
  icon         String
  color        String
  displayOrder Int         @default(0)
  genre        GenreFilter @default(HORROR)
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  games Game[]

  @@index([slug])
  @@map("categories")
}

/// بازی‌ها / تجربه‌ها
model Game {
  id          Int            @id @default(autoincrement())
  slug        String         @unique
  /// عنوان بازی به فارسی
  title       String
  /// زیرعنوان
  subtitle    String?
  categoryId  Int
  branchId    Int
  /// توضیحات کامل
  description String         @db.Text
  /// سناریو
  scenario    String?        @db.Text
  /// سطح ترس ۱-۵
  fearLevel   Int            @default(3)
  difficulty  GameDifficulty @default(MEDIUM)
  minPlayers  Int            @default(2)
  maxPlayers  Int            @default(6)
  /// مدت زمان به دقیقه
  durationMinutes Int        @default(60)
  /// قیمت به ازای هر نفر (تومان)
  pricePerPerson  BigInt
  /// رتبه‌بندی سایت (توسط ادمین تنظیم می‌شود) ۱-۵
  siteRank        Decimal    @default(4.0) @db.Decimal(3, 2)
  /// رتبه‌بندی کاربران (محاسبه‌شده از نظرات)
  userRankCached  Decimal?   @db.Decimal(3, 2)
  /// تعداد کل نظرات
  totalReviews    Int        @default(0)
  /// URL تیزر ویدئو
  teaserUrl       String?
  /// تصویر کاور اصلی
  coverImage      String?
  /// برچسب‌ها
  tags            String[]
  isFeatured      Boolean    @default(false)
  isActive        Boolean    @default(true)
  /// درصد تخفیف هفتگی (صفر = بدون تخفیف)
  weeklyDiscountPercent Int? @default(0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  category      Category        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  branch        Branch          @relation(fields: [branchId], references: [id], onDelete: Restrict)
  images        GameImage[]
  reviews       Review[]
  bookings      Booking[]
  teams         Team[]
  discountCodes DiscountCode[]  @relation("GameDiscounts")
  monthlyWins   MonthlyWinner[] @relation("WinnerGame")

  @@index([slug])
  @@index([categoryId])
  @@index([branchId])
  @@index([isActive, isFeatured])
  @@index([siteRank])
  freeTickets FreeTicket[]

  @@map("games")
}

/// تصاویر گالری بازی
model GameImage {
  id           Int      @id @default(autoincrement())
  gameId       Int
  url          String
  displayOrder Int      @default(0)
  caption      String?
  createdAt    DateTime @default(now())

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId])
  @@map("game_images")
}

// ─── کاربران ─────────────────────────────────────────────────

/// کاربران اصلی سیستم
model User {
  id          Int      @id @default(autoincrement())
  /// شماره موبایل — CITEXT برای جستجوی case-insensitive
  mobile      String   @unique @db.Citext
  email       String?  @unique @db.Citext
  fullName    String?
  nickname    String?  @unique
  avatarUrl   String?
  /// تنظیمات آواتار (JSON): {hatId, glassesId, skinId, effectId, backgroundId}
  avatarConfig Json?
  isActive    Boolean  @default(true)
  isBanned    Boolean  @default(false)
  isMuted     Boolean  @default(false)
  mutedUntil  DateTime?
  /// کد دعوت یونیک ۸ کاراکتری
  inviteCode  String   @unique
  /// کاربری که این کاربر را دعوت کرده
  invitedById Int?
  lastLoginAt DateTime?
  lastIp      String?
  /// تنظیمات شخصی: {notifications:{inapp:true,sms:true}, language:'fa', ...}
  settings    Json?
  /// [QA Fix 2026-05-25] bcrypt hash for admin/staff password login (null for OTP-only users)
  passwordHash String?
  /// [QA Fix 2026-05-25] Soft-delete flag (some legacy code expects this column)
  deletedAt   DateTime?
  banReason   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invitedBy          User?                @relation("InviteRelation", fields: [invitedById], references: [id], onDelete: SetNull)
  invitees           User[]               @relation("InviteRelation")
  profile            UserProfile?
  wallet             Wallet?
  roleAssignments    UserRoleAssignment[]
  bookings           Booking[]
  reviews            Review[]
  ratingsGiven       PlayerRating[]       @relation("RatingGiver")
  ratingsReceived    PlayerRating[]       @relation("RatingReceiver")
  notifications      Notification[]
  sessions           Session[]
  otpRequests        OtpRequest[]
  chatMessages       ChatMessage[]
  chatModerations    ChatModerationAction[] @relation("Moderator")
  chatModerated      ChatModerationAction[] @relation("ModeratedUser")
  teamsCaptain       Team[]               @relation("TeamCaptain")
  teamMemberships    TeamMember[]
  userBadges         UserBadge[]
  userAvatarItems    UserAvatarItem[]
  wheelSpins         WheelSpin[]
  inviteCodeRecord   InviteCode?
  inviteUsages       InviteUsage[]
  tickets            Ticket[]             @relation("TicketUser")
  ticketAssignments  Ticket[]             @relation("TicketAssignee")
  ticketMessages     TicketMessage[]
  campaignsCreated   Campaign[]
  pipelineDealsOwned Deal[]       @relation("DealOwner")
  pipelineDealsCustomer Deal[]    @relation("DealCustomer")
  payments           Payment[]
  managedBranches    Branch[]             @relation("BranchManager")
  auditLogsActor     AuditLog[]
  monthlyWinnerWins  MonthlyWinner[]      @relation("WinnerUser")
  smsLogs            SmsLog[]
  chatReportsFiled   ChatReport[]         @relation("ChatReportReporter")
  crmNotesAboutMe    CrmNote[]            @relation("CrmNoteUser")
  crmNotesIWrote     CrmNote[]            @relation("CrmNoteAuthor")
  campaignRecipients CampaignRecipient[]
  userSegments       UserSegment[]
  freeTickets        FreeTicket[]
  userAccessories    UserAccessory[]
  xpHistory          XpHistory[]

  @@index([mobile])
  @@index([email])
  @@index([inviteCode])
  @@index([isActive, isBanned])
  @@map("users")
}

/// تخصیص نقش به کاربر — چندنقشی
model UserRoleAssignment {
  userId    Int
  role      UserRole
  createdAt DateTime @default(now())
  grantedBy Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, role])
  @@map("user_role_assignments")
}

/// پروفایل گسترش‌یافته کاربر
model UserProfile {
  id                  Int      @id @default(autoincrement())
  userId              Int      @unique
  /// سطح فعلی (۱-۲۰)
  levelId             Int      @default(1)
  /// امتیاز تجربه
  xp                  Int      @default(0)
  /// تعداد کل رزروها
  totalBookings       Int      @default(0)
  /// تعداد رزروهای موفق (completed)
  successfulBookings  Int      @default(0)
  /// مجموع مبلغ خرج‌شده (تومان)
  totalSpent          BigInt   @default(0)
  averageRating       Decimal? @db.Decimal(3, 2)
  /// سطح ترس شخصی — مرتبط با تم Shadow Realm
  fearLevel           Decimal  @default(0) @db.Decimal(3, 1)
  bio                 String?  @db.Text
  instagramHandle     String?
  telegramHandle      String?
  birthDate           DateTime?
  gender              Gender?
  address             String?
  cityId              Int?
  /// آمار کش‌شده: {savesCount, completedRooms, badgesCount, ...}
  statsCache          Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  level Level @relation(fields: [levelId], references: [id], onDelete: Restrict)
  city  City? @relation(fields: [cityId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([levelId])
  @@index([xp])
  @@map("profiles")
}

// ─── کیف پول و تراکنش‌ها ──────────────────────────────────

/// کیف پول کاربر با ۳ بالانس
model Wallet {
  id               Int      @id @default(autoincrement())
  userId           Int      @unique
  /// موجودی تومانی
  tomanBalance     BigInt   @default(0)
  /// موجودی سکه
  coinsBalance     Int      @default(0)
  /// موجودی الماس
  diamondsBalance  Int      @default(0)
  isLocked         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  payments     Payment[]

  @@index([userId])
  @@map("wallets")
}

/// تاریخچه تراکنش‌های کیف پول
model Transaction {
  id           Int             @id @default(autoincrement())
  walletId     Int
  type         TransactionType
  currency     CurrencyType
  /// مقدار تراکنش (مثبت = دریافت، منفی = پرداخت)
  amount       BigInt
  /// موجودی بعد از تراکنش
  balanceAfter BigInt
  description  String?
  /// نوع ارجاع (booking, payment, wheel, ...)
  refType      String?
  /// شناسه ارجاع
  refId        Int?
  metadata     Json?
  createdAt    DateTime        @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([type])
  @@index([createdAt])
  @@map("transactions")
}

/// پرداخت‌ها (درگاه زرین‌پال و سایر)
model Payment {
  id               Int           @id @default(autoincrement())
  userId           Int
  bookingId        Int?          @unique
  walletId         Int?
  /// مبلغ پرداخت (تومان)
  amount           BigInt
  method           PaymentMethod
  status           PaymentStatus @default(PENDING)
  gateway          String?
  gatewayAuthority String?
  gatewayRefId     String?
  /// پاسخ کامل درگاه
  gatewayResponse  Json?
  paidAt           DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  wallet  Wallet?  @relation(fields: [walletId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([gatewayAuthority])
  @@index([createdAt])
  @@map("payments")
}

// ─── رزروها ──────────────────────────────────────────────────

/// رزروهای بازی
model Booking {
  id              Int           @id @default(autoincrement())
  /// کد یونیک ۸ کاراکتری رزرو
  code            String        @unique
  userId          Int
  gameId          Int
  branchId        Int
  /// تاریخ و زمان اسلات
  slotDateTime    DateTime
  playersCount    Int
  /// قیمت پایه (تومان)
  basePrice       BigInt
  /// مقدار تخفیف اعمال‌شده
  discountApplied BigInt        @default(0)
  /// مبلغ نهایی پرداختی
  totalAmount     BigInt
  status          BookingStatus @default(PENDING)
  paymentMethod   PaymentMethod @default(WALLET)
  discountCodeId  Int?
  note            String?
  completedAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  /// XP اعطاشده برای این رزرو
  rewardsEarnedXp    Int        @default(0)
  /// سکه اعطاشده برای این رزرو
  rewardsEarnedCoins Int        @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  game         Game          @relation(fields: [gameId], references: [id], onDelete: Restrict)
  branch       Branch        @relation(fields: [branchId], references: [id], onDelete: Restrict)
  discountCode DiscountCode? @relation(fields: [discountCodeId], references: [id], onDelete: SetNull)
  payment      Payment?
  review       Review?
  discountUsage DiscountUsage?
  playerRatings PlayerRating[]

  @@index([userId])
  @@index([gameId])
  @@index([branchId])
  @@index([status])
  @@index([slotDateTime])
  @@index([code])
  @@index([createdAt])
  freeTickets FreeTicket[]

  @@map("bookings")
}

// ─── نظرات و امتیازدهی ───────────────────────────────────────

/// نظرات کاربران روی بازی‌ها
model Review {
  id          Int      @id @default(autoincrement())
  /// هر رزرو فقط یک نظر
  bookingId   Int      @unique
  userId      Int
  gameId      Int
  /// امتیاز ۱-۵
  rating      Int
  text        String?  @db.Text
  isApproved  Boolean  @default(false)
  helpfulCount Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict)
  game    Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId])
  @@index([userId])
  @@index([isApproved])
  @@index([rating])
  @@map("game_reviews")
}

/// امتیازدهی مدیر شعبه به بازیکن
model PlayerRating {
  id         Int      @id @default(autoincrement())
  /// مدیر شعبه‌ای که امتیاز می‌دهد
  fromUserId Int
  /// بازیکنی که امتیاز می‌گیرد
  toUserId   Int
  bookingId  Int?
  /// تغییر XP (مثبت یا منفی)
  xpChange   Int
  reason     String?
  createdAt  DateTime @default(now())

  fromUser User     @relation("RatingGiver", fields: [fromUserId], references: [id], onDelete: Restrict)
  toUser   User     @relation("RatingReceiver", fields: [toUserId], references: [id], onDelete: Restrict)
  booking  Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([toUserId])
  @@index([fromUserId])
  @@map("player_ratings")
}

// ─── گیمیفیکیشن ──────────────────────────────────────────────

/// لول‌های بازی (۲۰ لول)
model Level {
  id          Int       @id
  /// نام لول به فارسی
  name        String
  tier        LevelTier
  /// XP مورد نیاز برای رسیدن به این لول
  requiredXp  Int
  /// مزایا و امتیازات JSON
  perks       Json?
  createdAt   DateTime  @default(now())

  profiles UserProfile[]

  @@map("levels")
}

/// نشان‌ها (Badges)
model Badge {
  id          Int      @id @default(autoincrement())
  /// کد یونیک
  code        String   @unique
  /// نام به فارسی
  name        String
  description String
  /// آیکون (FontAwesome class یا emoji)
  icon        String
  color       String
  /// شرایط اعطا JSON: {type: 'booking_count', value: 10}
  criteria    Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  userBadges UserBadge[]

  @@index([code])
  @@map("badges")
}

/// نشان‌های کسب‌شده توسط کاربر
model UserBadge {
  userId    Int
  badgeId   Int
  awardedAt DateTime @default(now())
  /// اگر توسط ادمین دستی اعطا شده
  awardedBy Int?

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@id([userId, badgeId])
  @@map("user_badges")
}

/// آیتم‌های آواتار قابل باز کردن
model AvatarItem {
  id             Int            @id @default(autoincrement())
  code           String         @unique
  /// نام به فارسی
  name           String
  type           AvatarItemType
  /// آیکون نمایشی
  icon           String
  imageUrl       String?
  /// حداقل لول برای باز کردن
  requiredLevel  Int            @default(1)
  /// قیمت به الماس (null = رایگان)
  priceDiamonds  Int?
  isDefault      Boolean        @default(false)
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())

  userItems UserAvatarItem[]

  @@index([type])
  userAccessories UserAccessory[]

  @@map("avatar_items")
}

/// آیتم‌های آواتار کسب‌شده توسط کاربر
model UserAvatarItem {
  userId      Int
  itemId      Int
  /// آیتم فعال فعلی (active در هر دسته)
  isActive    Boolean  @default(false)
  purchasedAt DateTime @default(now())

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  item AvatarItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([userId, itemId])
  @@map("user_avatar_items")
}

/// جوایز گردونه شانس
model WheelPrize {
  id                Int            @id @default(autoincrement())
  /// نام جایزه به فارسی
  name              String
  type              WheelPrizeType
  /// مقدار جایزه
  value             Int
  /// وزن احتمال (۱-۱۰۰ — relative weight)
  probabilityWeight Int
  color             String
  icon              String
  isActive          Boolean        @default(true)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  spins WheelSpin[]

  @@map("wheel_prizes")
}

/// تاریخچه چرخش گردونه شانس
model WheelSpin {
  id             Int          @id @default(autoincrement())
  userId         Int
  /// نوع ارز پرداخت‌شده
  paidWith       CurrencyType
  /// مقدار پرداخت‌شده
  costPaid       Int
  prizeId        Int
  /// اسنپ‌شات جایزه در زمان چرخش
  prizeSnapshot  Json
  awardedAt      DateTime     @default(now())

  user  User       @relation(fields: [userId], references: [id], onDelete: Restrict)
  prize WheelPrize @relation(fields: [prizeId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([awardedAt])
  @@map("wheel_spins")
}

// ─── سیستم دعوت ──────────────────────────────────────────────

/// کدهای دعوت کاربران
model InviteCode {
  id            Int      @id @default(autoincrement())
  userId        Int      @unique
  /// کد یونیک ۸ کاراکتری
  code          String   @unique
  totalUses     Int      @default(0)
  totalRewardXp Int      @default(0)
  createdAt     DateTime @default(now())

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  usages InviteUsage[]

  @@index([code])
  @@map("invite_codes")
}

/// استفاده از کد دعوت
model InviteUsage {
  id             Int      @id @default(autoincrement())
  codeId         Int
  /// کاربر دعوت‌شده (هر کاربر فقط یک بار می‌تواند از کد دعوت استفاده کند)
  invitedUserId  Int      @unique
  createdAt      DateTime @default(now())
  /// XP اعطاشده به دعوت‌کننده
  rewardXpGiven  Int      @default(5)

  code        InviteCode @relation(fields: [codeId], references: [id], onDelete: Cascade)
  invitedUser User       @relation(fields: [invitedUserId], references: [id], onDelete: Cascade)

  @@index([codeId])
  @@map("invite_usages")
}

// ─── چت و تیم‌سازی ───────────────────────────────────────────

/// اتاق‌های چت
model ChatRoom {
  id       Int          @id @default(autoincrement())
  type     ChatRoomType
  name     String?
  /// اتاق مخصوص تیم
  teamId   Int?         @unique
  isActive Boolean      @default(true)
  createdAt DateTime    @default(now())

  team     Team?         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@map("chat_rooms")
}

/// پیام‌های چت
model ChatMessage {
  id              Int               @id @default(autoincrement())
  roomId          Int
  userId          Int
  text            String            @db.Text
  status          ChatMessageStatus @default(NORMAL)
  reportsCount    Int               @default(0)
  /// شناسه پیام والد (برای reply)
  parentMessageId Int?
  createdAt       DateTime          @default(now())
  deletedAt       DateTime?

  room          ChatRoom      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  parentMessage ChatMessage?  @relation("MessageReply", fields: [parentMessageId], references: [id], onDelete: SetNull)
  replies       ChatMessage[] @relation("MessageReply")
  moderations   ChatModerationAction[]

  @@index([roomId])
  @@index([userId])
  @@index([createdAt])
  reports     ChatReport[]

  @@map("chat_messages")
}

/// اکشن‌های مدیریت چت
model ChatModerationAction {
  id          Int                  @id @default(autoincrement())
  messageId   Int?
  /// کاربر مورد عمل
  userId      Int
  /// ادمین/مدیر انجام‌دهنده
  moderatorId Int
  action      ModerationActionType
  reason      String?
  createdAt   DateTime             @default(now())

  message   ChatMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  user      User         @relation("ModeratedUser", fields: [userId], references: [id], onDelete: Cascade)
  moderator User         @relation("Moderator", fields: [moderatorId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@map("chat_moderation_actions")
}

/// تیم‌های بازی
model Team {
  id          Int        @id @default(autoincrement())
  /// نام تیم به فارسی
  name        String
  gameId      Int
  branchId    Int?
  captainId   Int
  capacity    Int
  slotDateTime DateTime?
  status      TeamStatus @default(FORMING)
  description String?    @db.Text
  isPublic    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  game           Game          @relation(fields: [gameId], references: [id], onDelete: Restrict)
  branch         Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  captain        User          @relation("TeamCaptain", fields: [captainId], references: [id], onDelete: Restrict)
  members        TeamMember[]
  chatRoom       ChatRoom?
  monthlyWins    MonthlyWinner[] @relation("WinnerTeam")

  @@index([gameId])
  @@index([status])
  @@map("teams")
}

/// اعضای تیم
model TeamMember {
  teamId   Int
  userId   Int
  joinedAt DateTime       @default(now())
  role     TeamMemberRole @default(MEMBER)

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
  @@map("team_members")
}

// ─── اعلان‌ها ─────────────────────────────────────────────────

/// اعلان‌های درون‌برنامه‌ای
model Notification {
  id        Int                 @id @default(autoincrement())
  userId    Int
  type      NotificationType
  channel   NotificationChannel @default(INAPP)
  title     String
  body      String
  link      String?
  isRead    Boolean             @default(false)
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

/// لاگ پیامک‌های ارسالی
model SmsLog {
  id          Int      @id @default(autoincrement())
  mobile      String
  template    String
  vars        Json?
  status      String
  providerRef String?
  sentAt      DateTime @default(now())
  error       String?
  userId      Int?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([mobile])
  @@index([sentAt])
  @@map("sms_logs")
}

// ─── تیکت پشتیبانی ───────────────────────────────────────────

/// تیکت‌های پشتیبانی
model Ticket {
  id          Int            @id @default(autoincrement())
  /// کد یونیک تیکت
  code        String         @unique
  userId      Int
  subject     String
  body        String         @db.Text
  priority    TicketPriority @default(MEDIUM)
  status      TicketStatus   @default(OPEN)
  assigneeId  Int?
  branchId    Int?
  lastReplyAt DateTime?
  closedAt    DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user     User            @relation("TicketUser", fields: [userId], references: [id], onDelete: Restrict)
  assignee User?           @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  branch   Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)
  messages TicketMessage[]

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@map("tickets")
}

/// پیام‌های تیکت
model TicketMessage {
  id           Int      @id @default(autoincrement())
  ticketId     Int
  senderId     Int
  body         String   @db.Text
  isStaffReply Boolean  @default(false)
  attachments  String[]
  createdAt    DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender User   @relation(fields: [senderId], references: [id], onDelete: Restrict)

  @@index([ticketId])
  @@map("ticket_messages")
}

// ─── CRM و بازاریابی ──────────────────────────────────────────

/// بخش‌بندی مشتریان
model Segment {
  id              Int      @id @default(autoincrement())
  name            String
  /// شرایط بخش‌بندی JSON: {rules: [{field, op, value}]}
  conditions      Json
  color           String
  icon            String
  cachedCount     Int      @default(0)
  lastComputedAt  DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  campaigns     Campaign[]
  discountCodes DiscountCode[]

  members UserSegment[]

  @@map("customer_segments")
}

/// کمپین‌های بازاریابی
model Campaign {
  id            Int            @id @default(autoincrement())
  name          String
  type          CampaignType
  status        CampaignStatus @default(DRAFT)
  segmentId     Int?
  /// محتوا JSON: {subject, body, templateVars, ...}
  content       Json
  scheduledAt   DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  budget        BigInt         @default(0)
  revenue       BigInt         @default(0)
  sentCount     Int            @default(0)
  openedCount   Int            @default(0)
  clickedCount  Int            @default(0)
  convertedCount Int           @default(0)
  createdBy     Int
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  segment   Segment? @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  creator   User             @relation(fields: [createdBy], references: [id], onDelete: Restrict)

  @@index([status])
  @@index([type])
  recipients CampaignRecipient[]

  @@map("campaigns")
}

/// پایپ‌لاین فروش (Kanban CRM)
model Deal {
  id               Int           @id @default(autoincrement())
  name             String
  /// شناسه مشتری (کاربر)
  customerId       Int?
  /// ارزش معامله (تومان)
  value            BigInt
  stage            PipelineStage @default(LEADS)
  /// ترتیب در Kanban
  position         Int
  ownerId          Int
  tag              String?
  expectedCloseDate DateTime?
  notes            String?       @db.Text
  lostReason       String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  customer User? @relation("DealCustomer", fields: [customerId], references: [id], onDelete: SetNull)
  owner    User  @relation("DealOwner", fields: [ownerId], references: [id], onDelete: Restrict)

  @@index([stage])
  @@index([ownerId])
  @@map("pipeline_deals")
}

// ─── تخفیف‌ها ─────────────────────────────────────────────────

/// کدهای تخفیف دستی
model DiscountCode {
  id              Int          @id @default(autoincrement())
  /// کد تخفیف — CITEXT
  code            String       @unique @db.Citext
  name            String?
  type            DiscountType
  /// مقدار تخفیف (درصد یا تومان)
  value           Int
  /// حداقل مبلغ خرید (تومان)
  minPurchase     BigInt       @default(0)
  /// حداکثر مبلغ تخفیف (برای نوع درصدی)
  maxDiscount     BigInt?
  validFrom       DateTime?
  validUntil      DateTime?
  maxUses         Int?
  usedCount       Int          @default(0)
  isActive        Boolean      @default(true)
  targetSegmentId Int?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  targetSegment Segment? @relation(fields: [targetSegmentId], references: [id], onDelete: SetNull)
  usages        DiscountUsage[]
  bookings      Booking[]
  games         Game[]           @relation("GameDiscounts")

  @@index([code])
  @@index([isActive])
  @@map("discount_codes")
}

/// تاریخچه استفاده از کد تخفیف
model DiscountUsage {
  id          Int      @id @default(autoincrement())
  codeId      Int
  userId      Int
  bookingId   Int      @unique
  savedAmount BigInt
  createdAt   DateTime @default(now())

  code    DiscountCode @relation(fields: [codeId], references: [id], onDelete: Cascade)
  booking Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([codeId])
  @@index([userId])
  @@map("discount_usages")
}

/// تخفیف‌های خودکار (rule-based)
model AutoDiscount {
  id         Int              @id @default(autoincrement())
  name       String
  type       DiscountType
  value      Int
  ruleType   AutoDiscountRule
  /// شرایط JSON: {minLevel, minBookings, ...}
  conditions Json?
  isActive   Boolean          @default(true)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([ruleType])
  @@map("auto_discounts")
}

// ─── تنظیمات سیستم ───────────────────────────────────────────

/// تنظیمات کلی سیستم (key-value)
model Setting {
  /// کلید CITEXT — PK
  key       String   @id @db.Citext
  /// مقدار JSON
  value     Json
  /// گروه: general|financial|chat|security|gamification|ai
  group     String
  updatedAt DateTime @updatedAt
  updatedBy Int?

  @@index([group])
  @@map("settings")
}

// ─── برندگان ماهانه ───────────────────────────────────────────

/// برندگان ماهانه (بازیکن برتر، تیم برتر، بازی برتر)
/// طراحی polymorphic: هر نوع FK جداگانه دارد (nullable)
/// TOP_PLAYER: winnerUserId دارد
/// TOP_TEAM:   winnerTeamId دارد
/// TOP_GAME:   winnerGameId دارد
model MonthlyWinner {
  id            Int               @id @default(autoincrement())
  year          Int
  month         Int
  type          MonthlyWinnerType
  /// شناسه کاربر برنده — فقط برای TOP_PLAYER
  winnerUserId  Int?
  /// شناسه تیم برنده — فقط برای TOP_TEAM
  winnerTeamId  Int?
  /// شناسه بازی برنده — فقط برای TOP_GAME
  winnerGameId  Int?
  prizeJson     Json
  distributedAt DateTime?
  distributedBy Int?
  createdAt     DateTime          @default(now())

  winnerUser User? @relation("WinnerUser", fields: [winnerUserId], references: [id], onDelete: SetNull)
  winnerTeam Team? @relation("WinnerTeam", fields: [winnerTeamId], references: [id], onDelete: SetNull)
  winnerGame Game? @relation("WinnerGame", fields: [winnerGameId], references: [id], onDelete: SetNull)

  @@unique([year, month, type])
  @@index([year, month])
  @@map("monthly_winners")
}

// ─── لاگ حسابرسی ─────────────────────────────────────────────

/// لاگ تغییرات مهم ادمین
model AuditLog {
  id         Int      @id @default(autoincrement())
  actorId    Int?
  /// کد اکشن: user.ban, booking.cancel, setting.update, ...
  action     String
  entity     String
  entityId   String?
  beforeJson Json?
  afterJson  Json?
  ip         String?
  ua         String?
  createdAt  DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── احراز هویت ──────────────────────────────────────────────

/// جلسات کاربری (refresh tokens)
model Session {
  id               Int      @id @default(autoincrement())
  userId           Int
  /// هش refresh token
  refreshTokenHash String
  ip               String?
  ua               String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

/// درخواست‌های OTP
model OtpRequest {
  id          Int      @id @default(autoincrement())
  mobile      String
  /// هش کد OTP
  codeHash    String
  attempts    Int      @default(0)
  expiresAt   DateTime
  verifiedAt  DateTime?
  ip          String?
  userId      Int?
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([mobile])
  @@index([expiresAt])
  @@map("otp_requests")
}

// ============================================================
// ■ ADDITIONAL MODELS — Required by Phase 3/4/5 Code
// ============================================================

/// گزارش پیام چت (توسط کاربران)
model ChatReport {
  id          Int      @id @default(autoincrement())
  messageId   Int
  reporterId  Int
  reason      String
  description String?  @db.Text
  status      String   @default("PENDING") // PENDING | REVIEWED | DISMISSED
  resolvedBy  Int?
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())

  message  ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  reporter User        @relation("ChatReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([status])
  @@map("chat_reports")
}

/// نقش‌های RBAC — جدول مرجع نقش‌ها با permissions
model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  displayName String
  description String?
  /// آرایه permissions به‌صورت JSON
  permissions Json
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("roles")
}

/// یادداشت‌های CRM
model CrmNote {
  id         Int      @id @default(autoincrement())
  userId     Int
  authorId   Int
  note       String   @db.Text
  isPinned   Boolean  @default(false)
  createdAt  DateTime @default(now())

  user   User @relation("CrmNoteUser", fields: [userId], references: [id], onDelete: Cascade)
  author User @relation("CrmNoteAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("crm_notes")
}

/// گیرندگان کمپین
model CampaignRecipient {
  id          Int      @id @default(autoincrement())
  campaignId  Int
  userId      Int
  status      String   @default("PENDING") // PENDING | SENT | DELIVERED | FAILED | OPENED | CLICKED
  sentAt      DateTime?
  deliveredAt DateTime?
  errorMsg    String?

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId])
  @@index([campaignId])
  @@index([status])
  @@map("campaign_recipients")
}

/// عضویت کاربر در سگمنت
model UserSegment {
  id        Int      @id @default(autoincrement())
  userId    Int
  segmentId Int
  joinedAt  DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  segment Segment @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  @@unique([userId, segmentId])
  @@index([segmentId])
  @@map("user_segments")
}

/// تیکت رایگان (پاداش)
model FreeTicket {
  id          Int       @id @default(autoincrement())
  userId      Int
  gameId      Int?
  source      String    // INVITE | WHEEL | MONTHLY | ADMIN
  expiresAt   DateTime?
  usedAt      DateTime?
  bookingId   Int?
  createdAt   DateTime  @default(now())

  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  game    Game? @relation(fields: [gameId], references: [id], onDelete: SetNull)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("free_tickets")
}

/// لوازم خریداری‌شده کاربر (alias for UserAvatarItem with different semantics)
model UserAccessory {
  id            Int      @id @default(autoincrement())
  userId        Int
  avatarItemId  Int
  isEquipped    Boolean  @default(false)
  purchasedAt   DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatarItem AvatarItem @relation(fields: [avatarItemId], references: [id], onDelete: Cascade)

  @@unique([userId, avatarItemId])
  @@map("user_accessories")
}

/// تاریخچه دریافت XP
model XpHistory {
  id        Int      @id @default(autoincrement())
  userId    Int
  amount    Int
  source    String   // BOOKING_COMPLETE | REVIEW | INVITE | WHEEL | LEVEL_UP | MANUAL
  refId     Int?     // bookingId / reviewId / etc.
  description String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("xp_history")
}
