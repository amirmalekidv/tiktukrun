// ─── چت و تیم‌سازی ───────────────────────────────────────────

model ChatRoom {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  type      ChatRoomType
  name      String?
  teamId    String?      @unique @db.ObjectId
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())

  team     Team?         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@map("chat_rooms")
}

model ChatMessage {
  id              String            @id @default(auto()) @map("_id") @db.ObjectId
  roomId          String            @db.ObjectId
  userId          String            @db.ObjectId
  text            String
  status          ChatMessageStatus @default(NORMAL)
  reportsCount    Int               @default(0)
  parentMessageId String?           @db.ObjectId
  createdAt       DateTime          @default(now())
  deletedAt       DateTime?

  room          ChatRoom               @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user          User                   @relation(fields: [userId], references: [id])
  parentMessage ChatMessage?           @relation("MessageReply", fields: [parentMessageId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies       ChatMessage[]          @relation("MessageReply")
  moderations   ChatModerationAction[]
  reports       ChatReport[]

  @@index([roomId])
  @@index([userId])
  @@index([createdAt])
  @@map("chat_messages")
}

model ChatModerationAction {
  id          String               @id @default(auto()) @map("_id") @db.ObjectId
  messageId   String?              @db.ObjectId
  userId      String               @db.ObjectId
  moderatorId String               @db.ObjectId
  action      ModerationActionType
  reason      String?
  createdAt   DateTime             @default(now())

  message   ChatMessage? @relation(fields: [messageId], references: [id])
  user      User         @relation("ModeratedUser", fields: [userId], references: [id], onDelete: Cascade)
  moderator User         @relation("Moderator", fields: [moderatorId], references: [id])

  @@index([userId])
  @@map("chat_moderation_actions")
}

model Team {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  gameId       String     @db.ObjectId
  branchId     String?    @db.ObjectId
  captainId    String     @db.ObjectId
  capacity     Int
  slotDateTime DateTime?
  status       TeamStatus @default(FORMING)
  description  String?
  isPublic     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  game        Game            @relation(fields: [gameId], references: [id])
  branch      Branch?         @relation(fields: [branchId], references: [id])
  captain     User            @relation("TeamCaptain", fields: [captainId], references: [id])
  members     TeamMember[]
  chatRoom    ChatRoom?
  monthlyWins MonthlyWinner[] @relation("WinnerTeam")

  @@index([gameId])
  @@index([status])
  @@map("teams")
}

model TeamMember {
  id       String         @id @default(auto()) @map("_id") @db.ObjectId
  teamId   String         @db.ObjectId
  userId   String         @db.ObjectId
  joinedAt DateTime       @default(now())
  role     TeamMemberRole @default(MEMBER)

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@map("team_members")
}

// ─── اعلان‌ها ─────────────────────────────────────────────────

model Notification {
  id        String              @id @default(auto()) @map("_id") @db.ObjectId
  userId    String              @db.ObjectId
  type      NotificationType
  channel   NotificationChannel @default(INAPP)
  title     String
  body      String
  link      String?
  isRead    Boolean             @default(false)
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model SmsLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  mobile      String
  template    String
  vars        Json?
  status      String
  providerRef String?
  sentAt      DateTime @default(now())
  error       String?
  userId      String?  @db.ObjectId

  user User? @relation(fields: [userId], references: [id])

  @@index([mobile])
  @@index([sentAt])
  @@map("sms_logs")
}

// ─── تیکت پشتیبانی ───────────────────────────────────────────

model Ticket {
  id          String         @id @default(auto()) @map("_id") @db.ObjectId
  code        String         @unique
  userId      String         @db.ObjectId
  subject     String
  body        String
  priority    TicketPriority @default(MEDIUM)
  status      TicketStatus   @default(OPEN)
  assigneeId  String?        @db.ObjectId
  branchId    String?        @db.ObjectId
  lastReplyAt DateTime?
  closedAt    DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user     User            @relation("TicketUser", fields: [userId], references: [id])
  assignee User?           @relation("TicketAssignee", fields: [assigneeId], references: [id])
  branch   Branch?         @relation(fields: [branchId], references: [id])
  messages TicketMessage[]

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@map("tickets")
}

model TicketMessage {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  ticketId     String   @db.ObjectId
  senderId     String   @db.ObjectId
  body         String
  isStaffReply Boolean  @default(false)
  attachments  String[]
  createdAt    DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender User   @relation(fields: [senderId], references: [id])

  @@index([ticketId])
  @@map("ticket_messages")
}

// ─── CRM و بازاریابی ──────────────────────────────────────────

model Segment {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  conditions     Json
  color          String
  icon           String
  cachedCount    Int       @default(0)
  lastComputedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  campaigns     Campaign[]
  discountCodes DiscountCode[]
  members       UserSegment[]

  @@map("customer_segments")
}

model Campaign {
  id             String         @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  type           CampaignType
  status         CampaignStatus @default(DRAFT)
  segmentId      String?        @db.ObjectId
  content        Json
  scheduledAt    DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  budget         Int            @default(0)
  revenue        Int            @default(0)
  sentCount      Int            @default(0)
  openedCount    Int            @default(0)
  clickedCount   Int            @default(0)
  convertedCount Int            @default(0)
  createdBy      String         @db.ObjectId
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  segment    Segment?            @relation(fields: [segmentId], references: [id])
  creator    User                @relation(fields: [createdBy], references: [id])
  recipients CampaignRecipient[]

  @@index([status])
  @@index([type])
  @@map("campaigns")
}

model Deal {
  id                String        @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  customerId        String?       @db.ObjectId
  value             Int
  stage             PipelineStage @default(LEADS)
  position          Int
  ownerId           String        @db.ObjectId
  tag               String?
  expectedCloseDate DateTime?
  notes             String?
  lostReason        String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  customer User? @relation("DealCustomer", fields: [customerId], references: [id])
  owner    User  @relation("DealOwner", fields: [ownerId], references: [id])

  @@index([stage])
  @@index([ownerId])
  @@map("pipeline_deals")
}

// ─── تخفیف‌ها ─────────────────────────────────────────────────

model DiscountCode {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  code            String       @unique
  name            String?
  type            DiscountType
  value           Int
  minPurchase     Int          @default(0)
  maxDiscount     Int?
  validFrom       DateTime?
  validUntil      DateTime?
  maxUses         Int?
  usedCount       Int          @default(0)
  isActive        Boolean      @default(true)
  targetSegmentId String?      @db.ObjectId
  gameIds         String[]     @db.ObjectId
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  targetSegment Segment?        @relation(fields: [targetSegmentId], references: [id])
  usages        DiscountUsage[]
  bookings      Booking[]
  games         Game[]          @relation("GameDiscounts", fields: [gameIds], references: [id])

  @@index([isActive])
  @@map("discount_codes")
}

model DiscountUsage {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  codeId      String   @db.ObjectId
  userId      String   @db.ObjectId
  bookingId   String   @unique @db.ObjectId
  savedAmount Int
  createdAt   DateTime @default(now())

  code    DiscountCode @relation(fields: [codeId], references: [id], onDelete: Cascade)
  booking Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([codeId])
  @@index([userId])
  @@map("discount_usages")
}

model AutoDiscount {
  id         String           @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  type       DiscountType
  value      Int
  ruleType   AutoDiscountRule
  conditions Json?
  isActive   Boolean          @default(true)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([ruleType])
  @@map("auto_discounts")
}

// ─── تنظیمات سیستم ───────────────────────────────────────────

model Setting {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   @unique
  value     Json
  group     String
  updatedAt DateTime @updatedAt
  updatedBy String?  @db.ObjectId

  @@index([group])
  @@map("settings")
}

// ─── برندگان ماهانه ───────────────────────────────────────────

model MonthlyWinner {
  id            String            @id @default(auto()) @map("_id") @db.ObjectId
  year          Int
  month         Int
  type          MonthlyWinnerType
  winnerUserId  String?           @db.ObjectId
  winnerTeamId  String?           @db.ObjectId
  winnerGameId  String?           @db.ObjectId
  prizeJson     Json
  distributedAt DateTime?
  distributedBy String?           @db.ObjectId
  createdAt     DateTime          @default(now())

  winnerUser User? @relation("WinnerUser", fields: [winnerUserId], references: [id])
  winnerTeam Team? @relation("WinnerTeam", fields: [winnerTeamId], references: [id])
  winnerGame Game? @relation("WinnerGame", fields: [winnerGameId], references: [id])

  @@unique([year, month, type])
  @@index([year, month])
  @@map("monthly_winners")
}

// ─── لاگ حسابرسی ─────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  actorId    String?  @db.ObjectId
  action     String
  entity     String
  entityId   String?
  beforeJson Json?
  afterJson  Json?
  ip         String?
  ua         String?
  createdAt  DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

