// ============================================================
// TIK TAK RUN — Prisma Schema (MongoDB)
// طراحی کامل دیتابیس پلتفرم رزرو سرگرمی — نسخه MongoDB
// تبدیل‌شده از PostgreSQL به MongoDB + قابلیت‌های جدید:
//   - سطح‌بندی بازی (GameTier): استاندارد/نقره‌ای/طلایی/پلاتینیوم/دایموند
//   - لایک بازی (GameLike)
//   - کامنت بازی + لایک کامنت (GameComment / GameCommentLike)
//   - دسته‌بندی‌های جدید: مافیا و لیزرتگ (در seed)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ============================================================
// ■ ENUMS
// ============================================================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  BRANCH_MANAGER
  SUPPORT
  MARKETING
  CUSTOMER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUND
}

enum PaymentMethod {
  WALLET
  ZARINPAL
  IDPAY
  BANK_TRANSFER
  CASH
}

enum TransactionType {
  DEPOSIT
  WITHDRAW
  BOOKING_PAYMENT
  REFUND
  WHEEL_SPEND
  WHEEL_WIN
  DIAMOND_PURCHASE
  COIN_PURCHASE
  INVITE_REWARD
  MONTHLY_REWARD
  MANUAL_ADJUST
  RATING_REWARD
}

enum CurrencyType {
  TOMAN
  COINS
  DIAMONDS
  XP
}

enum ChatRoomType {
  GLOBAL
  TEAM
  PRIVATE
}

enum ChatMessageStatus {
  NORMAL
  REPORTED
  HIDDEN
  DELETED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_USER
  RESOLVED
  CLOSED
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  PAUSED
  COMPLETED
}

enum CampaignType {
  SMS
  EMAIL
  INAPP
  PUSH
}

enum PipelineStage {
  LEADS
  CONTACTED
  PROPOSED
  NEGOTIATING
  CLOSED_WON
  CLOSED_LOST
}

enum DiscountType {
  PERCENT
  FIXED
}

enum AvatarItemType {
  HAT
  GLASSES
  SKIN
  EFFECT
  BACKGROUND
  ACCESSORY
}

enum WheelPrizeType {
  COINS
  DIAMONDS
  XP
  DISCOUNT_CODE
  FREE_TICKET
  TOMAN
}

enum LevelTier {
  BRONZE
  SILVER
  GOLD
  LEGEND
}

enum NotificationType {
  BOOKING
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_COMPLETED
  PAYMENT
  PAYMENT_FAILED
  REFUND_ISSUED
  LEVEL
  LEVEL_UP
  BADGE
  BADGE_EARNED
  WHEEL
  WHEEL_PRIZE
  TEAM
  TEAM_FULL
  CHAT
  SYSTEM
  PROMOTION
  CAMPAIGN
  PUSH_CAMPAIGN
  TICKET_REPLY
  REVIEW_APPROVED
  REVIEW_REJECTED
  MONTHLY_WINNER
}

enum NotificationChannel {
  INAPP
  SMS
  EMAIL
}

enum GameDifficulty {
  EASY
  MEDIUM
  HARD
  VERY_HARD
  LEGENDARY
}

/// سطح‌بندی بازی (جدید) — استاندارد، نقره‌ای، طلایی، پلاتینیوم، دایموند
enum GameTier {
  STANDARD
  SILVER
  GOLD
  PLATINUM
  DIAMOND
}

enum GenreFilter {
  HORROR
  NON_HORROR
}

enum LandingSectionFilterType {
  WEEKLY_DISCOUNT
  FEATURED
  CATEGORY
  CATEGORY_CITY
  MULTI_CATEGORY
  POPULAR_THIS_WEEK
  MANUAL
}

enum ModerationActionType {
  WARN
  MUTE_24H
  BAN
  DELETE_MSG
}

enum TeamStatus {
  FORMING
  FULL
  COMPLETED
  CANCELLED
}

enum TeamMemberRole {
  CAPTAIN
  MEMBER
}

enum MonthlyWinnerType {
  TOP_PLAYER
  TOP_TEAM
  TOP_GAME
  RAFFLE_WINNER
}

enum AutoDiscountRule {
  VIP
  WEEKLY
  FIRST_BOOKING
  BIRTHDAY
  INVITE
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

// ============================================================
// ■ MODELS
// ============================================================

// ─── جغرافیا ────────────────────────────────────────────────

model City {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  slug         String   @unique
  isActive     Boolean  @default(true)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  branches Branch[]
  profiles UserProfile[]

  @@map("cities")
}

model Branch {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  cityId    String   @db.ObjectId
  address   String
  phone     String?
  lat       Float?
  lng       Float?
  isActive  Boolean  @default(true)
  managerId String?  @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  city     City      @relation(fields: [cityId], references: [id])
  manager  User?     @relation("BranchManager", fields: [managerId], references: [id])
  games    Game[]
  bookings Booking[]
  tickets  Ticket[]
  teams    Team[]

  @@index([cityId])
  @@index([isActive])
  @@map("branches")
}

// ─── بازی‌ها ─────────────────────────────────────────────────

model Category {
  id           String      @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  slug         String      @unique
  icon         String
  color        String
  displayOrder Int         @default(0)
  genre        GenreFilter @default(HORROR)
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  games Game[]

  @@map("categories")
}

/// سکشن‌های صفحهٔ اصلی — قابل مدیریت از پنل ادمین
model LandingSection {
  id            String                   @id @default(auto()) @map("_id") @db.ObjectId
  key           String                   @unique
  title         String
  description   String?
  icon          String                   @default("fas fa-star")
  displayOrder  Int                      @default(0)
  isActive      Boolean                  @default(true)
  filterType    LandingSectionFilterType
  /// برای CATEGORY / CATEGORY_CITY
  categorySlug  String?
  /// برای MULTI_CATEGORY
  categorySlugs String[]
  /// برای CATEGORY_CITY
  citySlug      String?
  /// horror | non-horror — فیلتر بر اساس تگ «ترسناک»
  tagFilter     String?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  manualGames LandingSectionGame[]

  @@map("landing_sections")
}

model LandingSectionGame {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sectionId    String   @db.ObjectId
  gameId       String   @db.ObjectId
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())

  section LandingSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  game    Game           @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([sectionId, gameId])
  @@index([sectionId, displayOrder])
  @@map("landing_section_games")
}

/// بنرهای عریض صفحهٔ اصلی — قابل مدیریت از پنل ادمین
model LandingBanner {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  title        String?
  altText      String?
  href         String?
  imageUrl     String
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive, displayOrder])
  @@map("landing_banners")
}

/// معرفی پلتفرم در صفحهٔ اصلی (ویدئو + FAQ) — سینگلتون با key=default
model PlatformIntro {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  /// همیشه "default" — فقط یک رکورد فعال
  key       String   @unique @default("default")
  title     String   @default("معرفی پلتفرم تیک‌تاک‌ران")
  faqTitle  String   @default("سوالات متداول اتاق فرار - اسکیپ روم")
  videoUrl  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  faqs PlatformFaq[]

  @@map("platform_intro")
}

model PlatformFaq {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  introId      String   @db.ObjectId
  question     String
  answer       String
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  intro PlatformIntro @relation(fields: [introId], references: [id], onDelete: Cascade)

  @@index([introId, displayOrder])
  @@index([isActive, displayOrder])
  @@map("platform_faqs")
}

model Game {
  id                    String         @id @default(auto()) @map("_id") @db.ObjectId
  slug                  String         @unique
  title                 String
  subtitle              String?
  categoryId            String         @db.ObjectId
  branchId              String         @db.ObjectId
  description           String
  scenario              String?
  fearLevel             Int            @default(3)
  difficulty            GameDifficulty @default(MEDIUM)
  /// سطح‌بندی بازی — استاندارد/نقره‌ای/طلایی/پلاتینیوم/دایموند
  tier                  GameTier       @default(STANDARD)
  minPlayers            Int            @default(2)
  maxPlayers            Int            @default(6)
  durationMinutes       Int            @default(60)
  /// قیمت به ازای هر نفر (تومان)
  pricePerPerson        Int
  siteRank              Float          @default(4.0)
  userRankCached        Float?
  totalReviews          Int            @default(0)
  /// تعداد کل لایک‌های بازی (کش‌شده)
  likesCount            Int            @default(0)
  /// تعداد کل کامنت‌های تأییدشده (کش‌شده)
  commentsCount         Int            @default(0)
  teaserUrl             String?
  coverImage            String?
  tags                  String[]
  isFeatured            Boolean        @default(false)
  isActive              Boolean        @default(true)
  weeklyDiscountPercent Int?           @default(0)
  /// شناسه کدهای تخفیف مرتبط (m2m)
  discountCodeIds       String[]       @db.ObjectId
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  category            Category             @relation(fields: [categoryId], references: [id])
  branch              Branch               @relation(fields: [branchId], references: [id])
  images              GameImage[]
  reviews             Review[]
  comments            GameComment[]
  likes               GameLike[]
  bookings            Booking[]
  teams               Team[]
  discountCodes       DiscountCode[]       @relation("GameDiscounts", fields: [discountCodeIds], references: [id])
  monthlyWins         MonthlyWinner[]      @relation("WinnerGame")
  freeTickets         FreeTicket[]
  landingSectionGames LandingSectionGame[]

  @@index([categoryId])
  @@index([branchId])
  @@index([isActive, isFeatured])
  @@index([siteRank])
  @@index([tier])
  @@map("games")
}

model GameImage {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  gameId       String   @db.ObjectId
  url          String
  displayOrder Int      @default(0)
  caption      String?
  createdAt    DateTime @default(now())

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId])
  @@map("game_images")
}

/// لایک بازی (جدید) — هر کاربر یک‌بار می‌تواند یک بازی را لایک کند
model GameLike {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  gameId    String   @db.ObjectId
  userId    String   @db.ObjectId
  createdAt DateTime @default(now())

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([gameId, userId])
  @@index([gameId])
  @@index([userId])
  @@map("game_likes")
}

/// کامنت بازی (جدید) — مستقل از رزرو، با امکان تأیید توسط ادمین و لایک
model GameComment {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  gameId     String   @db.ObjectId
  userId     String   @db.ObjectId
  text       String
  /// شناسه کامنت والد برای پاسخ (reply)
  parentId   String?  @db.ObjectId
  isApproved Boolean  @default(false)
  isHidden   Boolean  @default(false)
  likesCount Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  game    Game              @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  GameComment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies GameComment[]     @relation("CommentReplies")
  likes   GameCommentLike[]

  @@index([gameId])
  @@index([userId])
  @@index([isApproved])
  @@index([parentId])
  @@map("game_comments")
}

/// لایک کامنت بازی (جدید)
model GameCommentLike {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  commentId String   @db.ObjectId
  userId    String   @db.ObjectId
  createdAt DateTime @default(now())

  comment GameComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId])
  @@map("game_comment_likes")
}

// ─── کاربران ─────────────────────────────────────────────────

model User {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  mobile       String    @unique
  email        String?   @unique
  fullName     String?
  nickname     String?   @unique
  avatarUrl    String?
  avatarConfig Json?
  isActive     Boolean   @default(true)
  isBanned     Boolean   @default(false)
  isMuted      Boolean   @default(false)
  mutedUntil   DateTime?
  inviteCode   String    @unique
  invitedById  String?   @db.ObjectId
  lastLoginAt  DateTime?
  lastIp       String?
  settings     Json?
  passwordHash String?
  deletedAt    DateTime?
  banReason    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  invitedBy             User?                  @relation("InviteRelation", fields: [invitedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  invitees              User[]                 @relation("InviteRelation")
  profile               UserProfile?
  wallet                Wallet?
  roleAssignments       UserRoleAssignment[]
  bookings              Booking[]
  reviews               Review[]
  gameComments          GameComment[]
  gameLikes             GameLike[]
  gameCommentLikes      GameCommentLike[]
  ratingsGiven          PlayerRating[]         @relation("RatingGiver")
  ratingsReceived       PlayerRating[]         @relation("RatingReceiver")
  notifications         Notification[]
  sessions              Session[]
  otpRequests           OtpRequest[]
  chatMessages          ChatMessage[]
  chatModerations       ChatModerationAction[] @relation("Moderator")
  chatModerated         ChatModerationAction[] @relation("ModeratedUser")
  teamsCaptain          Team[]                 @relation("TeamCaptain")
  teamMemberships       TeamMember[]
  userBadges            UserBadge[]
  userAvatarItems       UserAvatarItem[]
  wheelSpins            WheelSpin[]
  inviteCodeRecord      InviteCode?
  inviteUsages          InviteUsage[]
  tickets               Ticket[]               @relation("TicketUser")
  ticketAssignments     Ticket[]               @relation("TicketAssignee")
  ticketMessages        TicketMessage[]
  campaignsCreated      Campaign[]
  pipelineDealsOwned    Deal[]                 @relation("DealOwner")
  pipelineDealsCustomer Deal[]                 @relation("DealCustomer")
  payments              Payment[]
  managedBranches       Branch[]               @relation("BranchManager")
  auditLogsActor        AuditLog[]
  monthlyWinnerWins     MonthlyWinner[]        @relation("WinnerUser")
  smsLogs               SmsLog[]
  chatReportsFiled      ChatReport[]           @relation("ChatReportReporter")
  crmNotesAboutMe       CrmNote[]              @relation("CrmNoteUser")
  crmNotesIWrote        CrmNote[]              @relation("CrmNoteAuthor")
  campaignRecipients    CampaignRecipient[]
  userSegments          UserSegment[]
  freeTickets           FreeTicket[]
  userAccessories       UserAccessory[]
  xpHistory             XpHistory[]

  @@index([isActive, isBanned])
  @@map("users")
}

/// تخصیص نقش به کاربر — چندنقشی (composite key → unique compound)
model UserRoleAssignment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  role      UserRole
  createdAt DateTime @default(now())
  grantedBy String?  @db.ObjectId

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([userId])
  @@map("user_role_assignments")
}

model UserProfile {
  id                 String    @id @default(auto()) @map("_id") @db.ObjectId
  userId             String    @unique @db.ObjectId
  levelId            Int       @default(1)
  xp                 Int       @default(0)
  totalBookings      Int       @default(0)
  successfulBookings Int       @default(0)
  totalSpent         Int       @default(0)
  averageRating      Float?
  fearLevel          Float     @default(0)
  bio                String?
  instagramHandle    String?
  telegramHandle     String?
  birthDate          DateTime?
  gender             Gender?
  address            String?
  cityId             String?   @db.ObjectId
  statsCache         Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  level Level @relation(fields: [levelId], references: [id])
  city  City? @relation(fields: [cityId], references: [id])

  @@index([levelId])
  @@index([xp])
  @@map("profiles")
}

// ─── کیف پول و تراکنش‌ها ──────────────────────────────────

model Wallet {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String   @unique @db.ObjectId
  tomanBalance    Int      @default(0)
  coinsBalance    Int      @default(0)
  diamondsBalance Int      @default(0)
  isLocked        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  payments     Payment[]

  @@map("wallets")
}

model Transaction {
  id           String          @id @default(auto()) @map("_id") @db.ObjectId
  walletId     String          @db.ObjectId
  type         TransactionType
  currency     CurrencyType
  amount       Int
  balanceAfter Int
  description  String?
  refType      String?
  refId        String?
  metadata     Json?
  createdAt    DateTime        @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([type])
  @@index([createdAt])
  @@map("transactions")
}

model Payment {
  id               String        @id @default(auto()) @map("_id") @db.ObjectId
  userId           String        @db.ObjectId
  bookingId        String?       @unique @db.ObjectId
  walletId         String?       @db.ObjectId
  amount           Int
  method           PaymentMethod
  status           PaymentStatus @default(PENDING)
  gateway          String?
  gatewayAuthority String?
  gatewayRefId     String?
  gatewayResponse  Json?
  paidAt           DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  booking Booking? @relation(fields: [bookingId], references: [id])
  wallet  Wallet?  @relation(fields: [walletId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([gatewayAuthority])
  @@index([createdAt])
  @@map("payments")
}

// ─── رزروها ──────────────────────────────────────────────────

model Booking {
  id                 String        @id @default(auto()) @map("_id") @db.ObjectId
  code               String        @unique
  userId             String        @db.ObjectId
  gameId             String        @db.ObjectId
  branchId           String        @db.ObjectId
  slotDateTime       DateTime
  playersCount       Int
  teamName           String?
  basePrice          Int
  discountApplied    Int           @default(0)
  totalAmount        Int
  status             BookingStatus @default(PENDING)
  paymentMethod      PaymentMethod @default(WALLET)
  discountCodeId     String?       @db.ObjectId
  note               String?
  completedAt        DateTime?
  cancelledAt        DateTime?
  cancelReason       String?
  rewardsEarnedXp    Int           @default(0)
  rewardsEarnedCoins Int           @default(0)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  user          User           @relation(fields: [userId], references: [id])
  game          Game           @relation(fields: [gameId], references: [id])
  branch        Branch         @relation(fields: [branchId], references: [id])
  discountCode  DiscountCode?  @relation(fields: [discountCodeId], references: [id])
  payment       Payment?
  review        Review?
  discountUsage DiscountUsage?
  playerRatings PlayerRating[]
  freeTickets   FreeTicket[]

  @@index([userId])
  @@index([gameId])
  @@index([branchId])
  @@index([status])
  @@index([slotDateTime])
  @@index([createdAt])
  @@map("bookings")
}

// ─── نظرات و امتیازدهی ───────────────────────────────────────

model Review {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  bookingId    String   @unique @db.ObjectId
  userId       String   @db.ObjectId
  gameId       String   @db.ObjectId
  rating       Int
  text         String?
  isApproved   Boolean  @default(false)
  helpfulCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])
  game    Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId])
  @@index([userId])
  @@index([isApproved])
  @@index([rating])
  @@map("game_reviews")
}

model PlayerRating {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  fromUserId String   @db.ObjectId
  toUserId   String   @db.ObjectId
  bookingId  String?  @db.ObjectId
  xpChange   Int
  reason     String?
  createdAt  DateTime @default(now())

  fromUser User     @relation("RatingGiver", fields: [fromUserId], references: [id])
  toUser   User     @relation("RatingReceiver", fields: [toUserId], references: [id])
  booking  Booking? @relation(fields: [bookingId], references: [id])

  @@index([toUserId])
  @@index([fromUserId])
  @@map("player_ratings")
}

// ─── گیمیفیکیشن ──────────────────────────────────────────────

model Level {
  id         Int       @id @map("_id")
  name       String
  tier       LevelTier
  requiredXp Int
  perks      Json?
  createdAt  DateTime  @default(now())

  profiles UserProfile[]

  @@map("levels")
}

model Badge {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  code        String   @unique
