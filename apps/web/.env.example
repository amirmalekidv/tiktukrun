# TIK TAK RUN — Web (Next.js) environment example
# حالت دمو/موک — برای استفاده از بک‌اند واقعی روی false بگذارید
NEXT_PUBLIC_USE_MOCK=false

# آدرس API بک‌اند (شامل پیشوند /api/v1)
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# آدرس WebSocket (Socket.io) بک‌اند
NEXT_PUBLIC_WS_URL=http://localhost:4000

# کد OTP دمو که در صفحه لاگین نمایش داده می‌شود
NEXT_PUBLIC_DEMO_OTP_CODE=123456
