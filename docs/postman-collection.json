{
  "info": {
    "name": "TIK TAK RUN — Phase 5 API",
    "description": "Complete Phase 5 API: Gamification, Chat, CRM, Settings, Backup, Analytics",
    "version": "5.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:4000", "type": "string" },
    { "key": "token", "value": "YOUR_JWT_TOKEN_HERE", "type": "string" },
    { "key": "admin_token", "value": "YOUR_ADMIN_JWT_TOKEN_HERE", "type": "string" }
  ],
  "item": [
    {
      "name": "🎮 Gamification",
      "item": [
        {
          "name": "GET /api/v1/levels",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/levels",
            "description": "لیست ۲۰ لول"
          }
        },
        {
          "name": "GET /api/v1/badges",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/badges",
            "description": "لیست بج‌های فعال"
          }
        },
        {
          "name": "Admin: GET /api/v1/admin/levels",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/admin/levels",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }]
          }
        },
        {
          "name": "Admin: PATCH /api/v1/admin/levels/:id",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/api/v1/admin/levels/LEVEL_ID",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"requiredXp\": 1000, \"perks\": {\"accessories\": [], \"discount\": 10}}"
            }
          }
        },
        {
          "name": "Admin: POST /api/v1/admin/badges",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/admin/badges",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"code\": \"FIRST_BOOKING\", \"name\": \"اولین رزرو\", \"rarity\": \"COMMON\", \"triggerEvent\": \"booking_completed\"}"
            }
          }
        }
      ]
    },
    {
      "name": "🎡 Wheel",
