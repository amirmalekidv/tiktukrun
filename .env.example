# ═══════════════════════════════════════════════════════════════════════════
# TIK TAK RUN — Environment Variables (Complete)
# ═══════════════════════════════════════════════════════════════════════════
# نسخه: 1.0.0 — تولید فاز ۱۰ نهایی
# این فایل را به `.env` کپی کنید و مقادیر را پر کنید.
# ═══════════════════════════════════════════════════════════════════════════

# ─── App Environment ───────────────────────────────────────────────────────
NODE_ENV=production
TZ=Asia/Tehran
PROD_DOMAIN=tiktakrun.ir

# ─── Ports ─────────────────────────────────────────────────────────────────
API_PORT=4000
WEB_PORT=3000
ADMIN_PORT=3001

# ─── Public URLs (used in client builds & callbacks) ────────────────────────
WEB_URL=https://tiktakrun.ir
ADMIN_URL=https://admin.tiktakrun.ir
API_URL=https://api.tiktakrun.ir
SOCKET_URL=wss://api.tiktakrun.ir

# Next.js public (build-time inlined)
NEXT_PUBLIC_API_URL=https://api.tiktakrun.ir/api/v1
NEXT_PUBLIC_SOCKET_URL=wss://api.tiktakrun.ir
NEXT_PUBLIC_SITE_NAME=TIK TAK RUN
NEXT_PUBLIC_CONTACT_PHONE=02112345678
NEXT_PUBLIC_SUPPORT_EMAIL=support@tiktakrun.ir

# ─── Database (MongoDB 7 — Replica Set rs0) ────────────────────────────────
# MongoDB برای پشتیبانی از transaction های Prisma به replica set نیاز دارد.
MONGO_USER=tiktakrun
MONGO_PASSWORD=CHANGE_ME_to_strong_password
MONGO_DB=tiktakrun_db
# نکته: نام میزبان «mongo» نام سرویس داکر است. در حالت تک‌نودی replicaSet=rs0 و directConnection=true الزامی‌اند.
DATABASE_URL=mongodb://tiktakrun:CHANGE_ME_to_strong_password@mongo:27017/tiktakrun_db?authSource=admin&replicaSet=rs0&directConnection=true
# برای توسعه محلی (خارج از داکر) از این استفاده کنید:
# DATABASE_URL=mongodb://tiktakrun:CHANGE_ME_to_strong_password@127.0.0.1:27017/tiktakrun_db?authSource=admin&replicaSet=rs0&directConnection=true

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379

# ─── JWT ───────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_jwt_secret_at_least_32_chars_random
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret_at_least_32_chars_random
JWT_REFRESH_EXPIRES_IN=30d
COOKIE_SECRET=CHANGE_ME_cookie_secret_at_least_32_chars

# ─── OTP (SMS) ─────────────────────────────────────────────────────────────
SMS_MOCK_MODE=true                       # true در dev، false در production
SMSIR_API_KEY=                           # دریافت از sms.ir
SMSIR_LINE_NUMBER=                       # شماره خط ارسال
SMSIR_TEMPLATE_ID_OTP=                   # الگوی OTP
SMSIR_TEMPLATE_ID_NOTIFY=                # الگوی اطلاع‌رسانی
OTP_LENGTH=5
OTP_TTL_SECONDS=120
OTP_MAX_ATTEMPTS=3
OTP_RATE_LIMIT_PER_HOUR=5

# ─── Payment (ZarinPal) ────────────────────────────────────────────────────
ZARINPAL_MERCHANT_ID=00000000-0000-0000-0000-000000000000
ZARINPAL_SANDBOX=true                    # true در dev/test، false در production
ZARINPAL_CALLBACK_URL=https://tiktakrun.ir/api/v1/payments/verify
ZARINPAL_DESCRIPTION_PREFIX=شارژ کیف پول

# ─── Storage (Local file uploads) ──────────────────────────────────────────
STORAGE_PATH=/storage/uploads
STORAGE_PUBLIC_URL=https://tiktakrun.ir/uploads
MAX_UPLOAD_SIZE_MB=50
MAX_IMAGE_SIZE_MB=5
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
ALLOWED_VIDEO_TYPES=video/mp4,video/webm

# ─── Rate Limit ────────────────────────────────────────────────────────────
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=10

# ─── CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://tiktakrun.ir,https://admin.tiktakrun.ir

# ─── Monitoring (Optional) ─────────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=info

# ─── Gamification Tuning ──────────────────────────────────────────────────
XP_PER_BOOKING_COMPLETE=10
XP_PER_REVIEW=5
XP_PER_INVITE_USED=5
COINS_PER_LEVEL_UP=100

# ─── Wheel Costs ──────────────────────────────────────────────────────────
WHEEL_COST_XP=20
WHEEL_COST_COINS=500
WHEEL_COST_DIAMONDS=10

# ─── Default Admin Seed (used only by `pnpm seed`) ─────────────────────────
SEED_SUPERADMIN_MOBILE=09120000001
SEED_SUPERADMIN_PASSWORD=Admin@123456     # حتماً تغییر دهید بعد از اولین ورود!

# ─── Backup ────────────────────────────────────────────────────────────────
BACKUP_RETENTION_DAYS=14
BACKUP_PATH=/var/backups/tiktakrun
