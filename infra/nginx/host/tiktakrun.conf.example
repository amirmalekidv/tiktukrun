# ═══════════════════════════════════════════════════════════════════════════
# Host nginx snippet for modiranet-nginx (shared VPS)
# ═══════════════════════════════════════════════════════════════════════════
# Copy into modiranet nginx conf.d, then reload nginx + obtain SSL certs.
# Requires DEPLOY_MODE=shared and tiktakrun stack on 127.0.0.1:3000/3001/4000
# ═══════════════════════════════════════════════════════════════════════════

upstream tiktakrun_web {
    server 127.0.0.1:3000;
    keepalive 16;
}

upstream tiktakrun_admin {
    server 127.0.0.1:3001;
    keepalive 8;
}

upstream tiktakrun_api {
    server 127.0.0.1:4000;
    keepalive 16;
}

# ─── Main site ─────────────────────────────────────────────────────────────
server {
    listen 443 ssl http2;
    server_name tiktakrun.ir www.tiktakrun.ir;

    # ssl_certificate /etc/letsencrypt/live/tiktakrun.ir/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/tiktakrun.ir/privkey.pem;

    client_max_body_size 50m;

    location /api/ {
        proxy_pass http://tiktakrun_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /socket.io/ {
        proxy_pass http://tiktakrun_api;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_read_timeout 86400s;
    }

    location /uploads/ {
        alias /home/root/webapp/tiktakrun/storage/uploads/;
        expires 30d;
    }

    location / {
        proxy_pass http://tiktakrun_web;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

# ─── Admin ─────────────────────────────────────────────────────────────────
server {
    listen 443 ssl http2;
    server_name admin.tiktakrun.ir;

    location / {
        proxy_pass http://tiktakrun_admin;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

# ─── API subdomain ─────────────────────────────────────────────────────────
server {
    listen 443 ssl http2;
    server_name api.tiktakrun.ir;

    location / {
        proxy_pass http://tiktakrun_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /socket.io/ {
        proxy_pass http://tiktakrun_api;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_read_timeout 86400s;
    }
}
